{
  "name": "godot-mcp-pro",
  "version": "0.1.0",
  "description": "MCP and explicit CLI bridge for Godot MCP Pro editor tools",
  "type": "module",
  "bin": {
    "godot-mcp-pro": "./dist/src/main.js"
  },
  "files": ["dist", "package.json"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node dist/scripts/generate-manifest.js && npm run build && node --test test/*.test.mjs",
    "check": "npm run build && npm test -- --test-only",
    "start": "node dist/src/main.js",
    "generate-manifest": "node dist/scripts/generate-manifest.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "0.6.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/ws": "^8.5.12",
    "typescript": "^5.3.3"
  }
}
